source "https://rubygems.org"

# Use GitHub Pages' pinned versions of Jekyll + dependencies (prevents version conflicts)
gem "github-pages", group: :jekyll_plugins

# Allow remote_theme in _config.yml (e.g., pages-themes/leap-day)
gem "jekyll-remote-theme", group: :jekyll_plugins

# Needed for Ruby 3+ / Windows in many setups
gem "webrick", "~> 1.8"

# If you have any plugins, put them here (keep minimal for Pages compatibility)
group :jekyll_plugins do
  gem "jekyll-feed"
end

# Windows and JRuby does not include zoneinfo files, so bundle the tzinfo-data gem
# and associated library.
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end

# Performance-booster for watching directories on Windows
gem "wdm", "~> 0.1", platforms: [:mingw, :x64_mingw, :mswin]

# Lock `http_parser.rb` gem to `v0.6.x` on JRuby builds since newer versions do not have a Java counterpart.
gem "http_parser.rb", "~> 0.6.0", platforms: [:jruby]